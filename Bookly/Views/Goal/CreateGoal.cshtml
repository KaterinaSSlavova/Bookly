@model GoalViewModel

@{
    ViewData["Title"] = "Create Goal";
}

<h1>Create Goal</h1>
<hr />

@Html.Partial("_Alert")

<div class="d-flex justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-controller="Goal" asp-action="SaveGoal" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Start" class="form-label">Start Date</label>
                        <input asp-for="Start" type="date" class="form-control" />
                        <span asp-validation-for="Start" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="End" class="form-label">End Date</label>
                        <input asp-for="End" type="date" class="form-control" />
                        <span asp-validation-for="End" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReadingGoal" class="form-label">Set a reading goal</label>
                        <input asp-for="ReadingGoal" class="form-control" />
                        <span asp-validation-for="ReadingGoal" class="text-danger"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark">Save Goal</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
