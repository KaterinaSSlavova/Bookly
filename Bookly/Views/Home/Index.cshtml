@model List<BookViewModel>

@{
    ViewData["Title"] = "Home Page";
}

<h1>Books</h1>
<hr />

@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        <strong>@ViewBag.ErrorMessage</strong>
    </div>
}

<form asp-controller="Book" asp-action="GoToAddBook" method="post">
    <input type="submit" value="Add new book" class="btn btn-primary" />
</form>

<table class="table">
    <thead>
        <tr>
            <th>Cover</th>
            <th>Title</th>
            <th>Author</th>
            <th>Actions</th>
        </tr>
    </thead>
    @foreach (BookViewModel book in Model)
    {
        <tbody>
            <tr>
                <td>
                    <img src="@book.Picture" class="img-thumbnail" alt="@book.Title" style="max-width: 100px;" />
                </td>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>
                    <form asp-controller="Home" asp-action="ViewBook" method="post">
                        <input type="hidden" name="Id" value="@book.Id" />
                        <input type="submit" value="View" class="btn btn-primary" /> 
                    </form>
                </td>
            </tr>
        </tbody>
    }
</table>
