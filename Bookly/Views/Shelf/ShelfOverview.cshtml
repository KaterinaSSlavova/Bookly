@model List<RegularShelfViewModel>

@{
    ViewData["Title"] = "Shelf Overview";
}

<h1 class="mb-4">My Shelves</h1>
<hr />

@Html.Partial("_Alert")

<div class="mb-3">
    <form asp-controller="Shelf" asp-action="GoToCreatePage">
        <button type="submit" class="btn btn-primary">Create New Shelf</button>
    </form>
</div>

<div class="row">
    @foreach (RegularShelfViewModel shelf in Model)
    {
        <div class="col-md-6 col-lg-4 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">@shelf.Shelf.Name</h5>
                    <div class="d-flex justify-content-between">
                        @if (shelf.Shelf.Name != "Currently Reading")
                        {
                            <form asp-controller="Shelf" asp-action="ViewShelf">
                                <input type="hidden" name="id" value="@shelf.Shelf.Id" />
                                <button type="submit" class="btn btn-primary">View</button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="Shelf" asp-action="ViewCurrentlyReadingShelf">
                                <input type="hidden" name="id" value="@shelf.Shelf.Id" />
                                <button type="submit" class="btn btn-primary">View</button>
                            </form>
                        }
                        @if(shelf.Shelf.Name!="Have Read" && shelf.Shelf.Name != "Want To Read" && shelf.Shelf.Name != "Currently Reading")
                        {
                            <form asp-controller="Shelf" asp-action="RemoveShelf" method="post">
                                <input type="hidden" name="id" value="@shelf.Shelf.Id" />
                                <button type="submit" class="btn btn-danger">Remove Shelf</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
