@using Bookly.Models
@model Shelf

@{
    ViewData["Title"] = "Create Shelf";
}

<h1>New shelf</h1>
<hr />

@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        <strong>@ViewBag.ErrorMessage</strong>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <form asp-controller="Shelf" asp-action="CreateNewShelf">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label">Shelf Name:</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
        <form asp-controller="Shelf" asp-action="GoBack">
            <div class="form-group">
                <input type="submit" value="Go Back" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
