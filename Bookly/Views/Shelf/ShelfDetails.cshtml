@model RegularShelfViewModel

@{
    ViewData["Title"] = "Shelf Details";
}

<h1>@Model.Shelf.Name</h1>
<hr />

@Html.Partial("_Alert")

<table class="table">
    <thead>
        <tr>
            <th>Cover</th>
            <th>Title</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (BookViewModel book in Model.BooksOnShelf)
        {
            <tr>
                <td>
                    <img src="@book.Picture" class="img-thumbnail" alt="@book.Title" style="max-width: 100px;" />
                </td>
                <td>@book.Title</td>
                <td>

                    <form asp-controller="Book" asp-action="GetBookDetails" style="display:inline;">
                        <input type="hidden" name="Id" value="@book.Id" />
                        <input type="submit" value="View Book" class="btn btn-primary" />
                    </form>
                    <form asp-controller="Shelf" asp-action="RemoveFromShelf" style="display:inline;">
                        <input type="hidden" name="bookId" value="@book.Id" />
                        <input type="hidden" name="shelfId" value="@Model.Shelf.Id" />
                        <input type="submit" value="Remove from shelf" class="btn btn-danger" />
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<form asp-controller="Shelf" asp-action="GoBack">
    <div class="form-group">
        <input type="submit" value="Go Back" class="btn btn-primary" />
    </div>
</form>
