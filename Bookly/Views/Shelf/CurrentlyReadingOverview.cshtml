@model CurrentBookShelfViewModel

@{
    ViewData["Title"] = "Currently Reading Overview";
}

@Html.Partial("_Alert")

<h1>@Model.Shelf.Name</h1>
<hr />

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var book in Model.CurrentBooks)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@book.Book.Title</h5>
                    <p class="card-text">Author: <strong>@book.Book.Author</strong></p>
                    <p class="card-text"> <img src="@book.Book.Picture" class="card-img-top" alt="@book.Book.Title" /> </p>

                    <div class="progress mb-2">
                        <div class="progress-bar @(book.CurrentProgress >= book.Book.Pages ? "bg-success" : "bg-info")"
                             role="progressbar"
                             style="width: @(Math.Min((book.CurrentProgress / (double)book.Book.Pages) * 100, 100))%;"
                             aria-valuenow="@book.CurrentProgress"
                             aria-valuemin="0"
                             aria-valuemax="@book.Book.Pages">
                            @book.CurrentProgress / @book.Book.Pages
                        </div>
                    </div>

                    <p class="text-center">
                        @if (book.Status == "Completed")
                        {
                            <span class="badge bg-success">✅ Completed</span>
                        }
                        else if (book.Status == "In_progress")
                        {
                            <span class="badge bg-warning text-dark">⌛ In Progress</span>
                        }
                        else if (book.Status == "Not_started")
                        {
                            <span class="badge bg-secondary">🔧 Not Started</span>
                        }
                    </p>

                    <button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#modal-@book.Book.Id">
                        Update progress
                    </button>

                    <form asp-controller="Shelf" asp-action="UpdateCurrentBookProgress" method="post">
                        <div class="modal fade" id="modal-@book.Book.Id" tabindex="-1" aria-labelledby="modalLabel-@book.Book.Id" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form asp-controller="Shelf" asp-action="UpdateCurrentBookProgress" method="post">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="modalLabel-@book.Book.Id">@book.Book.Title</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">

                                            <img src="@book.Book.Picture" alt="Book Picture" class="img-fluid mb-3" />

                                            <div class="form-group">
                                                <label class="control-label" for="progress">Pages Read:</label>
                                                <input type="number" class="form-control" id="progress" name="progress" min="0" max="@book.Book.Pages" required />
                                                <small class="form-text text-muted">Out of @book.Book.Pages pages</small>
                                            </div>

                                            <input type="hidden" name="book.Book.Id" value="@book.Book.Id" />
                                            <input type="hidden" name="book.Book.Picture" value="@book.Book.Picture" />
                                            <input type="hidden" name="book.Book.Title" value="@book.Book.Title" />
                                            <input type="hidden" name="book.Book.Author" value="@book.Book.Author" />
                                            <input type="hidden" name="book.Book.Description" value="@book.Book.Description" />
                                            <input type="hidden" name="book.Book.ISBN" value="@book.Book.ISBN" />
                                            <input type="hidden" name="book.Book.Genre" value="@book.Book.Genre" />
                                            <input type="hidden" name="book.Book.Pages" value="@book.Book.Pages" />
                                            <input type="hidden" name="book.CurrentProgress" value="@book.CurrentProgress" />
                                            <input type="hidden" name="book.Status" value="@book.Status" />
                                        </div>
                                        <div class="modal-footer">
                                            <button type="submit" class="btn btn-success">Save progress</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </form>


                    <form asp-controller="Shelf" asp-action="RemoveFromCurrentBookShelf" method="post">
                        <input type="hidden" name="bookId" value="@book.Book.Id" />
                        <input type="hidden" name="shelfId" value="@Model.Shelf.Id" />
                        <input type="submit" value="Remove" class="btn btn-danger mb-3" />
                    </form>
                </div>
            </div>
        </div>
    }
</div>