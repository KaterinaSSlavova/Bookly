@model BookDetailsViewModel

@{
    string username = HttpContextAccessor.HttpContext.Session.GetString("Username");
    ViewData["Title"] = "Book Details";
}

<div class="container mt-5">
    <h1 class="display-5 mb-3">@Model.Book.Title</h1>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" role="alert">
            <strong>@TempData["Success"]</strong>
        </div>
    }

    @if (TempData["Review"] != null)
    {
        <div class="alert alert-success" role="alert">
            <strong>@TempData["Review"]</strong>
        </div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning" role="alert">
            <strong>@TempData["Warning"]</strong>
        </div>
    }

    @if (TempData["BookCatalogError"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>@TempData["BookCatalogError"]</strong>
        </div>
    }

    @if (TempData["Rating"] != null)
    {
        <div class="alert alert-success" role="alert">
            <strong>@TempData["Rating"]</strong>
        </div>
    }

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <img src="@Model.Book.Picture" class="card-img-top" alt="@Model.Book.Title" />
                <div class="card-body">
                    <h5 class="card-title">@Model.Book.Title</h5>
                    <p><strong>Author:</strong> @Model.Book.Author</p>
                    <p><strong>Genre:</strong> @Model.Book.Genre</p>
                    <p><strong>Description:</strong> @Model.Book.Description</p>
                    <p><strong>ISBN:</strong> @Model.Book.ISBN</p>
                    <p><strong>Pages:</strong> @Model.Book.Pages</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <h4>Rate This Book</h4>
            <form asp-controller="Rating" asp-action="RateABook" method="post" class="mb-4">
                <!-- Added mb-4 -->
                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                <div class="d-flex justify-content-between flex-wrap gap-2">
                    @foreach (var rating in new[] {
                    ("1", "Very_Sad", "😢"),
                    ("2", "Sad", "☹️"),
                    ("3", "Neutral", "😐"),
                    ("4", "Happy", "🙂"),
                    ("5", "Very_Happy", "😃")
                    })
                    {
                        <button type="submit" name="ratingId" value="@rating.Item1"
                                class="btn btn-outline-secondary @(Model.RatingFromUser == rating.Item2 ? "border-primary" : "")">
                            @rating.Item3
                        </button>
                    }
                </div>
            </form>

            <h4 class="mb-2">Move to Shelf</h4> 
            <form asp-controller="Shelf" asp-action="MoveToShelf" class="mb-4">
                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                        Select Shelf
                    </button>
                    <ul class="dropdown-menu w-100">
                        @foreach (var shelf in Model.Shelves)
                        {
                            <li>
                                <button type="submit" class="dropdown-item" name="shelfId" value="@shelf.Id">@shelf.Name</button>
                            </li>
                        }
                    </ul>
                </div>
            </form>

            <h4>Reviews</h4>
            @if (Model.Reviews?.Count > 0)
            {
                <ul class="list-group mb-3">
                    @foreach (var review in Model.Reviews)
                    {
                        <li class="list-group-item">
                            <strong>@review.Username:</strong> @review.Description
                            <br /><small class="text-muted">@review.Date</small>
                            @if (username == review.Username)
                            {
                                <form asp-controller="Review" asp-action="RemoveReview" class="mt-2">
                                    <input type="hidden" name="reviewId" value="@review.Id" />
                                    <input type="hidden" name="bookId" value="@Model.Book.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No reviews yet. Be the first to add one!</p>
            }

            <form asp-controller="Review" asp-action="CreateReview" method="post" class="mb-4">
                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                <div class="mb-3">
                    <label for="reviewDescription" class="form-label">Write a review:</label>
                    <textarea class="form-control" id="reviewDescription" name="description" rows="3" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Review</button>
            </form>

            <div class="d-grid gap-2 mb-4">
                <form asp-controller="Book" asp-action="GoToUpdateBook">
                    <input type="hidden" name="id" value="@Model.Book.Id" />
                    <button class="btn btn-warning">Update</button>
                </form>

                <form asp-controller="Book" asp-action="RemoveBook">
                    <input type="hidden" name="id" value="@Model.Book.Id" />
                    <button class="btn btn-danger">Remove Book</button>
                </form>

                <form asp-controller="Book" asp-action="GoBack">
                    <button class="btn btn-primary">Go Back</button>
                </form>
            </div>
        </div>
    </div>
</div>