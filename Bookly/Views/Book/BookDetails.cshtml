@model BookDetailsViewModel

@{
    ViewData["Title"] = "Book Details";
}

<div class="container mt-4">
    <h1 class="mb-3">@Model.Book.Title</h1>
    <hr />

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success" role="alert">
            <strong>@TempData["Message"]</strong>
        </div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning" role="alert">
            <strong>@TempData["Warning"]</strong>
        </div>
    }

    @if (TempData["BookCatalogError"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>@TempData["BookCatalogError"]</strong>
        </div>
    }

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-3">
                <img src="@Model.Book.Picture" class="card-img-top" alt="@Model.Book.Title" />
                <div class="card-body">
                    <h5 class="card-title">@Model.Book.Title</h5>
                    <p class="card-text"><strong>Author:</strong> @Model.Book.Author</p>
                    <p class="card-text"><strong>Genre:</strong> @Model.Book.Genre</p>
                    <p class="card-text"><strong>Description:</strong> @Model.Book.Description</p>
                    <p class="card-text"><strong>ISBN:</strong> @Model.Book.ISBN</p>
                </div>
            </div>

            <form asp-controller="Shelf" asp-action="MoveToShelf" class="mb-2">
                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                <div class="dropdown">
                    <button class="btn btn-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        Select shelf
                    </button>
                    <ul class="dropdown-menu w-100">
                        @foreach (ShelfViewModel shelf in Model.Shelves)
                        {
                            <li>
                                <button type="submit" class="dropdown-item" name="shelfId" value="@shelf.Id">@shelf.Name</button>
                            </li>
                        }
                    </ul>
                </div>
            </form>

            <div class="d-grid gap-2">
                <form asp-controller="Book" asp-action="RemoveBook">
                    <input type="hidden" name="id" value="@Model.Book.Id" />
                    <button type="submit" class="btn btn-danger">Remove Book</button>
                </form>

                <form asp-controller="Book" asp-action="GoBack">
                    <button type="submit" class="btn btn-primary">Go Back</button>
                </form>
            </div>

            <h3>Reviews</h3>
            @if (Model.Reviews != null && Model.Reviews.Count > 0)
            {
                <ul class="list-group">
                    @foreach (var review in Model.Reviews)
                    {
                        <li class="list-group-item">
                            <strong>@review.Username:</strong> @review.Description
                        </li>
                    }
                </ul>
            }
            else
            {
                <p>No reviews yet. Be the first to add one!</p>
            }

            <h3>Rate this book</h3>

            @if (TempData["Rating"] != null)
            {
                <div class="alert alert-success" role="alert">
                    <strong>@TempData["Rating"]</strong>
                </div>
            }

            <form asp-controller="Rating" asp-action="RateABook" method="post">
                <input type="hidden" name="bookId" value="@Model.Book.Id" />

                <div class="d-flex gap-2">
                    <button type="submit" name="ratingId" value="1"
                            class="btn btn-outline-secondary  @((Model.RatingFromUser == "Very_Sad") ? "selected" : "")">
                        😢
                    </button>
                    <button type="submit" name="ratingId" value="2"
                            class="btn btn-outline-secondary @((Model.RatingFromUser == "Sad") ? "selected" : "")">
                        ☹️
                    </button>
                    <button type="submit" name="ratingId" value="3"
                            class="btn btn-outline-secondary @((Model.RatingFromUser == "Neutral") ? "selected" : "")">
                        😐
                    </button>
                    <button type="submit" name="ratingId" value="4"
                            class="btn btn-outline-secondary @((Model.RatingFromUser == "Happy") ? "selected" : "")">
                        🙂
                    </button>
                    <button type="submit" name="ratingId" value="5"
                            class="btn btn-outline-secondary @((Model.RatingFromUser == "Very_Happy") ? "selected" : "")">
                        😃
                    </button>
                </div>
            </form>



         <form asp-controller="Review" asp-action="CreateReview" method="post">
    <input type="hidden" name="bookId" value="@Model.Book.Id" />

    <div class="mb-3">
        <label for="reviewDescription" class="form-label">Write a review:</label>
        <textarea class="form-control" id="reviewDescription" name="description" rows="3" required></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Submit Review</button>
</form> 
        </div>
    </div>
</div>