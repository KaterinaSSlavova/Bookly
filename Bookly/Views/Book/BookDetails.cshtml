@model BookDetailsViewModel

@{
    string username = HttpContextAccessor.HttpContext.Session.GetString("Username");
    string role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    ViewData["Title"] = "Book Details";
}

<div class="container mt-5">
    <h1 class="display-5 mb-3">@Model.Book.Title</h1>
    <hr />

    @Html.Partial("_Alert")

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <img src="@Model.Book.Picture" class="card-img-top" alt="@Model.Book.Title" />
                <div class="card-body">
                    <h5 class="card-title">@Model.Book.Title</h5>
                    <p><strong>Author:</strong> @Model.Book.Author</p>
                    <p><strong>Genre:</strong> @Model.Book.Genre</p>
                    <p><strong>Description:</strong> @Model.Book.Description</p>
                    <p><strong>ISBN:</strong> @Model.Book.ISBN</p>
                    <p><strong>Pages:</strong> @Model.Book.Pages</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <h4>Rate This Book</h4>
            <form asp-controller="Rating" asp-action="RateABook" method="post" class="mb-4">
                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                <div class="d-flex justify-content-between flex-wrap gap-2">
                    @foreach (var rating in Model.Ratings)
                    {
                        <button type="submit" name="ratingId" value="@rating.Value"
                                class="btn btn-outline-secondary @(Model.RatingFromUser == rating.Value ? "border-primary" : "")">
                            @rating.Text
                        </button>
                    }
                </div>
            </form>

            <h4 class="mb-2">Move to Shelf</h4>
            <form asp-controller="Shelf" asp-action="MoveToShelf" class="mb-4">
                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                        Select Shelf
                    </button>
                    <ul class="dropdown-menu w-100">
                        @foreach (var shelf in Model.Shelves)
                        {
                            <li>
                                <button type="submit" class="dropdown-item" name="shelfId" value="@shelf.Shelf.Id">@shelf.Shelf.Name</button>
                            </li>
                        }
                    </ul>
                </div>
            </form>

            <h4>Reviews</h4>

            @if (Model.Reviews?.Count > 0)
            {
                <div id="reviewCarousel" class="carousel slide mb-3" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i = 0; i < Model.Reviews.Count; i++)
                        {
                            var review = Model.Reviews[i];
                            var isActive = i == 0 ? "active" : "";
                            <div class="carousel-item @isActive">
                                <div class="card mx-auto" style="max-width: 600px;">
                                    <div class="card-body position-relative">
                                        <div class="dateReview">
                                            <small class="text-muted">@review.Date</small>
                                        </div>
                                        <img src="data:image/jpg;base64,@review.Picture" alt="@review.Username" class="user-picture rounded-circle me-2" />
                                        <h5 class="card-title">@review.Username</h5>
                                        <p class="card-text">@review.Description</p>

                                        @if (username == review.Username)
                                        {
                                            <form asp-controller="Review" asp-action="RemoveReview" class="mt-2">
                                                <input type="hidden" name="reviewId" value="@review.Id" />
                                                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <button class="carousel-control-next" type="button" data-bs-target="#reviewCarousel" data-bs-slide="next">
                        <span class="fs-2 text-dark" aria-hidden="true">&rsaquo;</span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>
            }
            else
            {
                <p class="text-muted">No reviews yet. Be the first to add one!</p>
            }

            <form asp-controller="Review" asp-action="CreateReview" method="post" class="mb-4">
                <input type="hidden" name="bookId" value="@Model.Book.Id" />
                <div class="mb-3">
                    <label for="reviewDescription" class="form-label">Write a review:</label>
                    <textarea class="form-control" id="reviewDescription" name="description" rows="3" required></textarea>
                </div>
                <div class="submitReview">
                    <button type="submit" class="btn btn-dark">Submit Review</button>
                </div>
            </form>

            <div class="d-flex flex-column align-items-center gap-3 mb-4">

                @if (role == Role.Manager.ToString())
                {
                    <form asp-controller="Book" asp-action="GoToUpdateBook" class="w-100" style="max-width: 500px;">
                        <input type="hidden" name="id" value="@Model.Book.Id" />
                        <button class="btn btn-warning w-100">Update</button>
                    </form>

                    <form asp-controller="Book" asp-action="RemoveBook" class="w-100" style="max-width: 500px;">
                        <input type="hidden" name="id" value="@Model.Book.Id" />
                        <button class="btn btn-danger w-100">Remove Book</button>
                    </form>
                }

                <form asp-controller="Book" asp-action="GoBack" class="w-100" style="max-width: 500px;">
                    <button class="btn btn-dark w-100">Go Back</button>
                </form>

            </div>
        </div>
    </div>
</div>
