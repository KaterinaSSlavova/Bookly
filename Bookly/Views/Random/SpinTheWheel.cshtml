@model BookViewModel


@{
    ViewData["Title"] = "Spin the Wheel";
}

@Html.Partial("_Alert")

<h1>Spin The Wheel</h1>
<hr />

<form asp-controller="Random" asp-action="Spin" method="post" class="mb-3">
    <button type="submit" class="btn btn-secondary">Spin</button>
</form>

<button type="button" class="btn btn-primary mb-4" data-bs-toggle="modal" data-bs-target="#bookModal">
    Show Book
</button>

@if (Model != null)
{
    <div class="modal fade" id="bookModal" tabindex="-1" aria-labelledby="bookModalLabel" aria-hidden="true">
        <form asp-controller="Random" asp-action="AddBookFromSpinTheWheel" method="post">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title" id="bookModalLabel">@Model.Title</h5>
                        <input type="hidden" name="Id" value="@Model.Id" />
                        <input type="hidden" name="Title" value="@Model.Title" />
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <input type="hidden" name="Picture" value="@Model.Picture" />
                        <img src="@Model.Picture" alt="Book Picture" class="img-fluid mb-3" />

                        <input type="hidden" name="Author" value="@Model.Author" />
                        <p><strong>Author:</strong> @Model.Author</p>

                        <input type="hidden" name="Description" value="@Model.Description" />
                        <p><strong>Description:</strong> @Model.Description</p>

                        <input type="hidden" name="Genre" value="@Model.Genre" />
                        <p><strong>Genre:</strong> @Model.Genre</p>

                        <input type="hidden" name="ISBN" value="@Model.ISBN" />
                        <p><strong>ISBN:</strong> @Model.ISBN</p>
                    </div>

                        <button type="submit" class="btn btn-success">Add to Want To Read</button>

                </div>
            </div>
        </form>
    </div>
}


