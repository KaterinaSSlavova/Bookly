@model DateWithABookViewModel

@{
    ViewData["Title"] = "Random date with a book";
}

<h1>Random Date With A Book</h1>
<hr />

@if (TempData["DateIndication"] != null)
{
    <div class="alert alert-info" role="alert">
        <strong>@TempData["DateIndication"]</strong>
    </div>
}

@if (Model.FilteredBooks != null && Model.FilteredBooks.Any())
{
    foreach (BookViewModel book in Model.FilteredBooks)
    {
        <label>@book.Description</label>
        <form asp-controller="Random" asp-action="SelectDescription" method="post">
            <input type="hidden" name="Id" value="@book.Id" />
            <input type="submit" value="Select" class="btn btn-primary" />
        </form>
    }
}
else
{
    <form asp-controller="Random" asp-action="FilterBooks" method="post">
        <div class="form-group">
            <label for="RatingSelect" class="control-label">Select Rating:</label>
            <select name="ratings" class="form-select">
                <option value="">Select a Rating</option>
                @foreach (var rating in Model.Ratings)
                {
                    <option value="@rating.Value">@rating.Text</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label for="GenreSelect" class="control-label">Genre:</label>
            <select name="genre" class="form-select">
                <option value="">Select a Genre</option>
                @foreach (var genre in Model.Genres)
                {
                    <option value="@genre.Value">@genre.Text</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-secondary">Filter</button>
    </form>
}