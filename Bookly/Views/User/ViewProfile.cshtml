@using Bookly.Data.Models
@model User
@{
    ViewData["Title"] = "View Profile";
}

<h1>Profile</h1>
<hr />

@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        <strong>@ViewBag.ErrorMessage</strong>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <form asp-controller="User" asp-action="ViewProfile">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group text-left">
                    <img src="data:image/jpeg;base64,@Model.Picture" class="img-thumbnail" alt="@Model.Username" />
            </div>
            <div class="form-group text-left">
                <label><strong>Username:</strong> @Model.Username</label>
            </div>
            <div class="form-group text-left">
                <label><strong>Email:</strong> @Model.Email</label>
            </div>
            <div class="form-group text-left">
                <label><strong>Age:</strong> @Model.Age</label>
            </div>
            <div class="form-group text-left">
                <label><strong>Password:</strong> (Hidden for security)</label>
            </div>

            <input type="hidden" name="UserId" value="@Model.Id" />
        </form>
        <form asp-controller="User" asp-action="EditProfile">
            <div class="form-group text-left">
                <input type="submit" value="Edit" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
