@model ProfileOverviewModel
@{
    ViewData["Title"] = "View Profile";
}

<h1>Profile</h1>
<hr />

@if (TempData["ProfileUpdated"] != null)
{
    <div class="alert alert-success" role="alert">
        <strong>@TempData["ProfileUpdated"]</strong>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <form asp-controller="User" asp-action="ViewProfile">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div>
                <p>@Model.Picture</p> 
            </div>


            <div class="form-group text-left">
                    <img src="data:image/jpg;base64,@Model.Picture" class="img-thumbnail" alt="@Model.Username" />
            </div>
            <div class="form-group text-left">
                <label><strong>Username:</strong> @Model.Username</label>
            </div>
            <div class="form-group text-left">
                <label><strong>Email:</strong> @Model.Email</label>
            </div>
            <div class="form-group text-left">
                <label><strong>Age:</strong> @Model.Age</label>
            </div>

            <input type="hidden" name="UserId" value="@Model.Id" />
        </form>
        <form asp-controller="User" asp-action="GoToEdit" method="post">
            <div class="form-group text-left">
                <input type="submit" value="Edit" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
