@model ProfileOverviewModel

@{
    ViewData["Title"] = "View Profile";
}

<h1>Profile</h1>
<hr />

@Html.Partial("_Alert")

<div class="d-flex justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body text-center">
                <img src="data:image/jpg;base64,@Model.Picture" class="img-thumbnail mb-3" alt="@Model.Username" style="max-width: 150px;" />

                <ul class="list-group list-group-flush text-start mb-3">
                    <li class="list-group-item"><strong>Username:</strong> @Model.Username</li>
                    <li class="list-group-item"><strong>Email:</strong> @Model.Email</li>
                    <li class="list-group-item"><strong>Age:</strong> @Model.Age</li>
                    <li class="list-group-item"><strong>Role:</strong> @Model.Role</li>
                </ul>

                <form asp-controller="User" asp-action="GoToEdit" method="post">
                    <input type="hidden" name="UserId" value="@Model.Id" />
                    <button type="submit" class="btn btn-dark w-100">Edit</button>
                </form>
            </div>
        </div>
    </div>
</div>
